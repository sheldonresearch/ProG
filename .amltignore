# .amltignore — exclude heavy / regenerable dirs from amulet code upload.
# Syntax mirrors .gitignore. Applied IN ADDITION to anything passed via
# the yaml `code.ignore:` list.
#
# Big dirs that absolutely must not be uploaded (52+ GB combined).
# Leading-slash anchors these to the repo root so we don't accidentally
# exclude prompt_graph/data/ (the Python package!) or similar.
/data/
/dataset/
/Experiment/
/.git/
/amlt/
/amulet_plan_a_out/
/merged_results/
/tmp_amlt_out/

# Python / build artifacts
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Local virtual envs
.venv/
venv/
env/

# Logs we don't need on the worker
scripts/baseline_logs/
scripts/bench_logs/

# Heavy images / archives (worker doesn't need these)
Logo.jpg
ProG_pipeline.jpg
Experiment.zip
Node.zip
*.tar.gz
*.zip
